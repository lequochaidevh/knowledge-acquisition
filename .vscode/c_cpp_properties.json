{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/linux/common/logging/**",
                "${workspaceFolder}/linux/common/ipc/**",
                "${workspaceFolder}/linux/common/**",
                "${workspaceFolder}/internal_root/include/**"
            ],
            "forcedInclude": [],
